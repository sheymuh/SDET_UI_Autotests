<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="SelenoidParallelSuite" parallel="tests" thread-count="3">
    <listeners>
        <listener class-name="com.simbirsoft.helpers.AnnotationTransformer"/>
    </listeners>
    <test name="ChromeTests">
        <parameter name="browser" value="chrome"/>
        <parameter name="executionMode" value="selenoid"/>
        <classes>
            <class name="com.simbirsoft.tests.LoginPageTests"/>
<!--            <class name="com.simbirsoft.tests.BankingAppPageTests"/>-->
<!--            <class name="com.simbirsoft.tests.CookiesTests"/>-->
        </classes>
    </test>
    <test name="FirefoxTests">
        <parameter name="browser" value="firefox"/>
        <parameter name="executionMode" value="selenoid"/>
        <classes>
<!--            <class name="com.simbirsoft.tests.LoginPageTests"/>-->
            <class name="com.simbirsoft.tests.BankingAppPageTests"/>
<!--            <class name="com.simbirsoft.tests.CookiesTests"/>-->
<!--            <class name="com.simbirsoft.tests.UIFunctionalityTests"/>-->
        </classes>
    </test>
    <test name="EdgeTests">
        <parameter name="browser" value="edge"/>
        <parameter name="executionMode" value="selenoid"/>
        <classes>
<!--            <class name="com.simbirsoft.tests.LoginPageTests"/>-->
<!--            <class name="com.simbirsoft.tests.BankingAppPageTests"/>-->
<!--            <class name="com.simbirsoft.tests.CookiesTests"/>-->
            <class name="com.simbirsoft.tests.UIFunctionalityTests"/>
        </classes>
    </test>
</suite>